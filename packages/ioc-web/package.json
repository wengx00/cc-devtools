{
  "name": "@cc-devtools/ioc-web",
  "version": "0.0.0-alpha.14",
  "type": "module",
  "files": [
    "dist",
    "types"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./types/index.d.ts",
  "exports": {
    "types": "./types/index.d.ts",
    "import": "./dist/index.js",
    "require": "./dist/index.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && esbuild src/index.ts --platform=node --format=esm --bundle --outfile=./dist/index.js --sourcemap=external --minify --target=es2020 && esbuild src/index.ts --platform=node --format=cjs --bundle --outfile=./dist/index.cjs --sourcemap=external --minify --target=es2020",
    "dopublish": "pnpm build && pnpm publish --registry=https://registry.npmjs.org/ --no-git-checks --access=public"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
