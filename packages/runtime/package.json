{
  "name": "@cc-scaffold/runtime",
  "version": "0.0.1",
  "type": "module",
  "private": "true",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "dopublish": "pnpm build && pnpm publish --registry=https://registry.npmjs.org/ --no-git-checks"
  },
  "eslintIgnore": [
    "dist",
    "node_modules",
    "vite.config.ts"
  ],
  "files": [
    "dist"
  ],
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@scaffold/eslint-config": "workspace:^",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "eslint": "^8.57.0",
    "lint-staged": "^15.2.2",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.9.0"
  },
  "exports": {
    ".": {
      "import": "./dist/@scaffold/runtime.js",
      "require": "./dist/@scaffold/runtime.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  }
}
